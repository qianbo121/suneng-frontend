# 生产数据库密码。示例：DB_PASSWORD=请替换为强密码
DB_PASSWORD=please_change_database_password

# 后台 JWT 签名密钥。示例：JWT_SECRET=一段至少32位的随机字符串
JWT_SECRET=please_change_jwt_secret_at_least_32_chars

# 官网主域名，不要带 http/https。示例：DOMAIN=www.sunengfurnace.com
DOMAIN=www.example.com

# 后台管理域名，不要带 http/https。示例：ADMIN_DOMAIN=admin.sunengfurnace.com
ADMIN_DOMAIN=admin.example.com

# JWT 有效期，默认 7d。示例：JWT_EXPIRES_IN=7d
JWT_EXPIRES_IN=7d

# 单文件上传大小限制，单位 MB，默认 10。示例：UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_MAX_FILE_SIZE_MB=10

# 后台登录最大失败次数，默认 5。示例：ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_MAX_ATTEMPTS=5

# 后台登录失败锁定时间，单位分钟，默认 15。示例：ADMIN_LOGIN_LOCK_MINUTES=15
ADMIN_LOGIN_LOCK_MINUTES=15
